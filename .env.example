# PostgreSQL — Timeweb Cloud (прод) или Docker (локально)
# Timeweb: https://timeweb.cloud/my/databases → кластер → вкладка «Подключение»
# ВАЖНО для Vercel: при создании кластера включите публичный доступ (публичный IP)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/zoopsych?sslmode=require"

# Локально (docker compose up -d):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zoopsych"

# Секрет для сессий (openssl rand -base64 32)
SESSION_SECRET=change-me-to-random-32-chars-min

# ЮKassa — https://yookassa.ru/my/merchant/integration/api-keys
YOOKASSA_SHOP_ID=000000
YOOKASSA_SECRET_KEY=test_...

# Чеки 54-ФЗ — включите после подключения онлайн-кассы в ЮKassa
# YOOKASSA_SEND_RECEIPT=true

# URL сайта (для return_url после оплаты)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Реквизиты для оферты (/offer, /privacy). Для портфолио — demo ниже; для продакшена — ИП/ООО
LEGAL_SELLER_NAME=Autonomika Studio · portfolio demo
LEGAL_SELLER_EMAIL=hello@autonomika.dev
NEXT_PUBLIC_PORTFOLIO_AUTHOR=Autonomika
# NEXT_PUBLIC_GITHUB_URL=https://github.com/you/dog-zoopsychology
# LEGAL_SELLER_INN=123456789012
# LEGAL_SELLER_OGRNIP=123456789012345
# LEGAL_SELLER_ADDRESS=г. Москва, ул. Примерная, д. 1

# Цена курса в рублях — значения должны совпадать
COURSE_PRICE=1990
NEXT_PUBLIC_COURSE_PRICE=1990
